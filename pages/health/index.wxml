<view class="container {{seniorMode ? 'senior' : ''}}">
  <view wx:if="{{loading}}" class="muted">加载中...</view>
  <view wx:if="{{error}}" class="card error">{{error}}</view>
  <view class="card">
    <view class="title">健康数据看板</view>
    <view class="muted">展示步数与睡眠概览（MVP 使用 Mock 数据）</view>
  </view>

  <view class="card" wx:for="{{snapshots}}" wx:key="date">
    <view>{{item.date}}</view>
    <view class="muted" wx:if="{{visibility.share_step_band}}">步数：{{item.steps}}</view>
    <view class="muted" wx:if="{{visibility.share_sleep_summary}}">睡眠：{{item.sleep_hours}}h</view>
    <view class="muted" wx:if="{{!visibility.share_step_band && !visibility.share_sleep_summary}}">该成员关闭了健康摘要共享</view>
  </view>
</view>
