/* 健康页：提醒列表分隔（表单基类在 app.wxss） */

.error {
  color: #c44d4d;
}

.reminder-item {
  border-top: 1rpx solid rgba(42, 34, 27, 0.08);
  padding-top: 16rpx;
  margin-top: 16rpx;
}

.reminder-item:first-of-type {
  border-top: none;
  padding-top: 0;
  margin-top: 0;
}

.inline-num {
  width: 120rpx;
  text-align: right;
  margin: 0;
}

.reminder-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 12rpx;
}
