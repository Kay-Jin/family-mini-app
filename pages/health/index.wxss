.error {
  color: #c44d4d;
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 10rpx 0;
}

.input {
  border: 1rpx solid rgba(42, 34, 27, 0.1);
  border-radius: 12rpx;
  padding: 14rpx;
  margin: 10rpx 0;
}

.picker-val {
  color: #567a58;
}

.reminder-item {
  border-top: 1rpx solid rgba(42, 34, 27, 0.08);
  padding-top: 12rpx;
  margin-top: 12rpx;
}

.inline-num {
  width: 120rpx;
  text-align: right;
  margin: 0;
}

.reminder-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 12rpx;
}

