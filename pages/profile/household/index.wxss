.error {
  color: #c44d4d;
}

.role-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.picker {
  margin-top: 10rpx;
  color: #2d6d5f;
}

.input-like {
  margin-top: 12rpx;
  padding: 16rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(42, 34, 27, 0.12);
  background: #faf8f5;
}

.danger-zone {
  border: 1rpx solid rgba(180, 80, 80, 0.28);
}

.btn-dissolve {
  margin-top: 20rpx;
  background: #fff5f5;
  color: #a94442;
  border: 1rpx solid rgba(180, 80, 80, 0.45);
  border-radius: 14rpx;
  min-height: 88rpx;
}

