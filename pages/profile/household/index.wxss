.error {
  color: #c44d4d;
}

.role-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.picker {
  margin-top: 10rpx;
  color: #2d6d5f;
}

.input-like {
  margin-top: 12rpx;
  padding: 16rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(42, 34, 27, 0.12);
  background: #faf8f5;
}

.danger-zone {
  border: 1rpx solid rgba(180, 80, 80, 0.28);
}

.invite-row {
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(42, 34, 27, 0.08);
}

.invite-row:last-child {
  border-bottom: none;
}

.btn-mini-revoke {
  margin-top: 8rpx;
}

.btn-dissolve {
  margin-top: 20rpx;
  background: #fff5f5;
  color: #a94442;
  border: 1rpx solid rgba(180, 80, 80, 0.45);
  border-radius: 14rpx;
  min-height: 88rpx;
}

.member-list-hint {
  margin-bottom: 16rpx;
  font-size: 26rpx;
  line-height: 1.45;
}

.member-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(42, 34, 27, 0.08);
}

.member-row:last-child {
  border-bottom: none;
}

.member-main {
  flex: 1;
  min-width: 0;
}

.member-name {
  font-weight: 600;
  color: #2a221b;
  margin-bottom: 6rpx;
}

.member-role-picker {
  flex-shrink: 0;
  margin-top: 0;
  white-space: nowrap;
}

