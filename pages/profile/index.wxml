<view class="container {{seniorMode ? 'senior' : ''}}">
  <view class="card">
    <view class="title">家账号与设置</view>
    <view class="row">
      <text>长辈模式</text>
      <switch checked="{{seniorMode}}" bindchange="onSeniorSwitch" />
    </view>
    <view class="muted">开启后会放大字号和按钮点击区域。</view>
  </view>

  <view class="card">
    <view class="title">角色模拟（MVP）</view>
    <radio-group bindchange="onRoleChange">
      <label wx:for="{{roleOptions}}" wx:key="value" class="role-item">
        <radio value="{{item.value}}" checked="{{role === item.value}}" />
        <text>{{item.label}}</text>
      </label>
    </radio-group>
  </view>

  <view class="card">
    <view class="title">接口配置</view>
    <radio-group bindchange="onBackendModeChange">
      <label wx:for="{{backendModeOptions}}" wx:key="value" class="role-item">
        <radio value="{{item.value}}" checked="{{backendMode === item.value}}" />
        <text>{{item.label}}</text>
      </label>
    </radio-group>
    <input wx:if="{{backendMode === 'http'}}" class="input" placeholder="API Base URL" value="{{apiBaseUrl}}" bindinput="onApiInput" />
    <input wx:if="{{backendMode === 'cloudbase'}}" class="input" placeholder="CloudBase Env ID" value="{{cloudEnvId}}" bindinput="onCloudEnvInput" />
    <input wx:if="{{backendMode !== 'mock'}}" class="input" placeholder="Bearer Token（可选）" value="{{authToken}}" bindinput="onTokenInput" />
    <button class="btn-primary" bindtap="onSaveApiConfig">保存接口配置</button>
  </view>

  <view class="card" bindtap="goHousehold">
    <view>家庭组织与权限</view>
  </view>

  <view class="card" bindtap="goVisibility">
    <view>可见性与隐私</view>
  </view>

  <view class="card" wx:if="{{backendMode === 'cloudbase' && myHouseholds.length > 1}}">
    <view class="title">切换家庭</view>
    <view class="muted">当前已加入多个家庭，点击下方切换活跃家庭。</view>
    <view
      wx:for="{{myHouseholds}}"
      wx:key="householdId"
      class="household-row"
      bindtap="onSwitchHousehold"
      data-hid="{{item.householdId}}"
    >
      <text>{{item.name || '家庭'}}</text>
      <text class="muted"> · {{item.role}}</text>
    </view>
  </view>

  <view class="card danger-zone" wx:if="{{backendMode === 'cloudbase'}}">
    <view class="title">家庭账号</view>
    <view class="muted">退出后需重新创建家庭或输入邀请码加入。</view>
    <button class="btn-leave" bindtap="onLeaveHousehold">退出当前家庭</button>
  </view>
</view>
