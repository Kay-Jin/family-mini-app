<view class="container {{seniorMode ? 'senior' : ''}}">
  <view wx:if="{{loading}}" class="loading-hint muted">正在加载</view>
  <view wx:if="{{error}}" class="card error">{{error}}</view>
  <view class="card">
    <view class="title">可见性配置</view>
    <view class="item">
      <text>分享步数区间</text>
      <switch data-key="share_step_band" checked="{{form.share_step_band}}" bindchange="onToggle" />
    </view>
    <view class="item">
      <text>分享睡眠摘要</text>
      <switch data-key="share_sleep_summary" checked="{{form.share_sleep_summary}}" bindchange="onToggle" />
    </view>
    <view class="item">
      <text>分享天气</text>
      <switch data-key="share_city_weather" checked="{{form.share_city_weather}}" bindchange="onToggle" />
    </view>
    <view class="item">
      <text>分享最近报平安时间</text>
      <switch data-key="share_last_checkin_time" checked="{{form.share_last_checkin_time}}" bindchange="onToggle" />
    </view>
    <view class="item">
      <text>允许相册共建</text>
      <switch data-key="share_album_contribute" checked="{{form.share_album_contribute}}" bindchange="onToggle" />
    </view>
    <view class="item">
      <text>加入晨报摘要</text>
      <switch data-key="include_in_morning_brief" checked="{{form.include_in_morning_brief}}" bindchange="onToggle" />
    </view>
  </view>
</view>
