.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.role-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.input {
  border: 1rpx solid rgba(28, 27, 26, 0.1);
  border-radius: 12rpx;
  padding: 16rpx;
  margin: 10rpx 0;
}

.danger-zone {
  border: 1rpx solid rgba(180, 80, 80, 0.25);
}

.btn-leave {
  margin-top: 20rpx;
  background: #fff5f5;
  color: #a94442;
  border: 1rpx solid rgba(180, 80, 80, 0.45);
  border-radius: 14rpx;
  min-height: 88rpx;
}
