.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.role-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.input {
  border: 1rpx solid rgba(28, 27, 26, 0.1);
  border-radius: 12rpx;
  padding: 16rpx;
  margin: 10rpx 0;
}
