<view class="container">
  <view wx:if="{{loading}}" class="muted">加载中...</view>
  <view wx:if="{{error}}" class="card error">{{error}}</view>
  <view class="card">
    <view class="title">家庭相册</view>
    <button class="btn-primary" bindtap="onUploadTap" wx:if="{{role !== 'senior'}}">上传照片</button>
    <view class="muted" wx:if="{{role === 'senior'}}">长辈账号默认仅浏览，上传入口可由家人代操作。</view>
  </view>

  <view class="card" wx:for="{{items}}" wx:key="id">
    <image wx:if="{{item.thumb_url}}" class="thumb" mode="aspectFill" src="{{item.thumb_url}}" />
    <view>{{item.uploaded_by}} · {{item.created_at}}</view>
    <view class="muted">标签：{{item.tags.join(" / ")}}</view>
  </view>
</view>
