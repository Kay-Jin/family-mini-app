<view class="container">
  <view class="card">
    <view class="title">家庭相册</view>
    <button class="btn-primary" bindtap="onUploadTap">上传照片</button>
  </view>

  <view class="card" wx:for="{{items}}" wx:key="id">
    <view>{{item.uploaded_by}} · {{item.created_at}}</view>
    <view class="muted">标签：{{item.tags.join(" / ")}}</view>
  </view>
</view>
