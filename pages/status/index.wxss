.input {
  border: 1rpx solid rgba(42, 34, 27, 0.1);
  border-radius: 14rpx;
  padding: 16rpx;
  margin: 10rpx 0;
  background: #faf8f5;
  color: #2a221b;
}

.status-item {
  border-top: 1rpx solid rgba(42, 34, 27, 0.08);
  padding-top: 16rpx;
  margin-top: 16rpx;
}

.status-item:first-of-type {
  border-top: none;
  padding-top: 0;
  margin-top: 0;
}
