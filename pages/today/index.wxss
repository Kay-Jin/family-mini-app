/* 今日页局部：预警、求助、周报高亮（全局 token 见 app.wxss） */

.line {
  margin-bottom: 12rpx;
  color: #2a221b;
}

.error {
  color: #c44d4d;
}

.line-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
  min-height: 72rpx;
}

.picker-val {
  color: #567a58;
}

.alert-head {
  color: #c44d4d;
  background: rgba(196, 77, 77, 0.08);
  border: 1rpx solid rgba(196, 77, 77, 0.28);
  border-radius: 10rpx;
  padding: 12rpx 16rpx;
  margin-bottom: 12rpx;
  font-size: 26rpx;
}

.alert-item {
  color: #2a221b;
  margin-top: 10rpx;
  padding: 14rpx 16rpx;
  background: #fff8f8;
  border-left: 6rpx solid #c44d4d;
  border-radius: 8rpx;
}

.alert-badge {
  display: inline-block;
  background: #c44d4d;
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  margin-right: 10rpx;
  vertical-align: middle;
}

.alert-card {
  border-color: rgba(196, 77, 77, 0.32);
}

.card-critical-edge {
  border-left: 8rpx solid #d6a35e;
  background: linear-gradient(90deg, rgba(214, 163, 94, 0.12) 0%, #ffffff 40%);
}

.help-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin: 16rpx 0;
}

.help-chip {
  flex: 1;
  min-width: 200rpx;
  font-size: 26rpx;
  padding: 12rpx 8rpx;
}

.small-btn {
  margin-top: 16rpx;
  min-height: 72rpx;
  font-size: 28rpx;
}

.time-input {
  border: 1rpx solid rgba(86, 122, 88, 0.28);
  border-radius: 14rpx;
  padding: 12rpx 16rpx;
  min-width: 160rpx;
  text-align: right;
  background: #faf8f5;
  font-size: 28rpx;
  color: #2a221b;
}

.small-print {
  font-size: 22rpx;
  margin: 12rpx 0;
  color: #655a4f;
  line-height: 1.45;
}

.help-line {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 12rpx;
}

.help-type-tag {
  background: rgba(214, 163, 94, 0.25);
  color: #8c6346;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.link-cancel {
  margin-left: auto;
  color: #567a58;
  background: transparent;
  border: none;
  font-size: 26rpx;
  padding: 0 8rpx;
}

.link-cancel::after {
  border: none;
}
