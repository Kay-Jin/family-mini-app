.line {
  margin-bottom: 12rpx;
  color: #2a221b;
}

.error {
  color: #c44d4d;
}

.line-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.picker-val {
  color: #567a58;
}

.alert-head {
  color: #a33a3a;
  background: #fdf0f0;
  border: 1rpx solid rgba(196, 77, 77, 0.25);
  border-radius: 10rpx;
  padding: 8rpx 12rpx;
  margin-bottom: 12rpx;
}

.alert-item {
  color: #7d2f2f;
  margin-top: 10rpx;
  padding: 10rpx 12rpx;
  background: #fff6f6;
  border-left: 6rpx solid #c44d4d;
  border-radius: 8rpx;
}

.alert-badge {
  display: inline-block;
  background: #c44d4d;
  color: #fff;
  font-size: 22rpx;
  padding: 2rpx 10rpx;
  border-radius: 999rpx;
  margin-right: 10rpx;
}

.alert-card {
  border-color: rgba(196, 77, 77, 0.35);
}

.card-critical-edge {
  border-left: 8rpx solid #d6a35e;
}

.help-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin: 16rpx 0;
}

.help-chip {
  flex: 1;
  min-width: 200rpx;
  font-size: 26rpx;
  padding: 12rpx 8rpx;
}

.small-btn {
  margin-top: 16rpx;
  min-height: 72rpx;
  font-size: 28rpx;
}

.time-input {
  border: 1rpx solid rgba(62, 95, 68, 0.2);
  border-radius: 10rpx;
  padding: 8rpx 12rpx;
  min-width: 160rpx;
  text-align: right;
}

.small-print {
  font-size: 22rpx;
  margin: 12rpx 0;
}

.help-line {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 12rpx;
}

.help-type-tag {
  background: #fff3e0;
  color: #8c6346;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.link-cancel {
  margin-left: auto;
  color: #567a58;
  background: transparent;
  border: none;
}
