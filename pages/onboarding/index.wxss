.error {
  border-color: rgba(180, 80, 80, 0.35);
}

.input {
  margin-top: 16rpx;
  padding: 20rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(42, 34, 27, 0.15);
  background: #faf8f5;
}

.btn-secondary {
  margin-top: 16rpx;
  background: #e8e2d8;
  color: #2a221b;
  border-radius: 14rpx;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

button + .btn-primary {
  margin-top: 16rpx;
}
