.error {
  border-color: rgba(180, 80, 80, 0.35);
}

.input {
  margin-top: 16rpx;
  padding: 20rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(42, 34, 27, 0.15);
  background: #faf8f5;
}

.pick-row {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(42, 34, 27, 0.08);
  box-shadow: 0 8rpx 20rpx rgba(86, 122, 88, 0.08);
}

button + .btn-primary {
  margin-top: 16rpx;
}
