<view class="container">
  <view wx:if="{{loading}}" class="muted">加载中...</view>

  <view wx:if="{{!loading && bootstrapError}}" class="card error">
    <view class="title">无法连接云服务</view>
    <view class="muted">{{bootstrapError}}</view>
    <button class="btn-primary" bindtap="onRetryBootstrap">重试</button>
  </view>

  <block wx:if="{{!loading && !bootstrapError && mode === 'choose'}}">
    <view class="card">
      <view class="title">欢迎使用</view>
      <view class="muted">请选择创建新家庭，或使用邀请码加入已有家庭。</view>
    </view>
    <button class="btn-primary" bindtap="goCreate">创建家庭</button>
    <button class="btn-secondary" bindtap="goJoin">加入家庭（邀请码）</button>
  </block>

  <block wx:if="{{!loading && !bootstrapError && mode === 'create'}}">
    <view class="card">
      <view class="title">创建家庭</view>
      <input
        class="input"
        placeholder="家庭名称"
        value="{{householdName}}"
        bindinput="onHouseholdNameInput"
      />
    </view>
    <button class="btn-primary" bindtap="onCreateHousehold" disabled="{{submitting}}">
      {{submitting ? "提交中…" : "创建并进入"}}
    </button>
    <button class="btn-secondary" bindtap="backChoose" disabled="{{submitting}}">返回</button>
  </block>

  <block wx:if="{{!loading && !bootstrapError && mode === 'join'}}">
    <view class="card">
      <view class="title">加入家庭</view>
      <input
        class="input"
        placeholder="邀请码（如 ADU-XXXXXX）"
        value="{{inviteCode}}"
        bindinput="onInviteCodeInput"
      />
      <input
        class="input"
        placeholder="您的称呼（选填）"
        value="{{displayName}}"
        bindinput="onDisplayNameInput"
      />
    </view>
    <button class="btn-primary" bindtap="onJoinHousehold" disabled="{{submitting}}">
      {{submitting ? "提交中…" : "加入家庭"}}
    </button>
    <button class="btn-secondary" bindtap="backChoose" disabled="{{submitting}}">返回</button>
  </block>
</view>
