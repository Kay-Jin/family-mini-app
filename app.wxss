page {
  background: #f7f1e8;
  color: #2a221b;
  font-size: 30rpx;
}

.container {
  padding: 24rpx;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 20rpx rgba(86, 122, 88, 0.1);
  border: 1rpx solid rgba(42, 34, 27, 0.06);
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: #2a221b;
}

.muted {
  color: #655a4f;
}

/* 轻量加载反馈（避免仅纯文字） */
@keyframes loading-pulse {
  0%,
  100% {
    opacity: 0.35;
  }
  50% {
    opacity: 1;
  }
}

.loading-hint {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 0 16rpx;
  animation: loading-pulse 1.2s ease-in-out infinite;
}

.loading-hint::before {
  content: "";
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #567a58;
}

.btn-primary {
  background: #567a58;
  color: #ffffff;
  border-radius: 14rpx;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-secondary {
  margin-top: 16rpx;
  background: #e8e2d8;
  color: #2a221b;
  border-radius: 14rpx;
  min-height: 88rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.senior {
  font-size: 34rpx;
}

.senior .title {
  font-size: 42rpx;
}

.senior .btn-primary,
.senior .btn-secondary,
.senior button {
  min-height: 96rpx;
  font-size: 34rpx;
}
