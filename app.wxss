page {
  background: #f7f1e8;
  color: #2a221b;
  font-size: 30rpx;
}

.container {
  padding: 24rpx;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 20rpx rgba(86, 122, 88, 0.1);
  border: 1rpx solid rgba(42, 34, 27, 0.06);
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: #2a221b;
}

.muted {
  color: #655a4f;
}

.btn-primary {
  background: #567a58;
  color: #ffffff;
  border-radius: 14rpx;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.senior {
  font-size: 34rpx;
}

.senior .title {
  font-size: 42rpx;
}

.senior .btn-primary,
.senior button {
  min-height: 96rpx;
  font-size: 34rpx;
}
