page {
  background: #f4f3f0;
  color: #1c1b1a;
  font-size: 30rpx;
}

.container {
  padding: 24rpx;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 20rpx rgba(40, 81, 58, 0.08);
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.muted {
  color: #6b7473;
}

.btn-primary {
  background: #2d6d5f;
  color: #ffffff;
}

.senior {
  font-size: 34rpx;
}

.senior .title {
  font-size: 42rpx;
}

.senior .btn-primary,
.senior button {
  min-height: 96rpx;
  font-size: 34rpx;
}
